		//==============================================================================================
		//==== SPACECORE ANIMATIONS ====================================================================
		//==============================================================================================
		{
			"Action": "EditData",
			"Target": "spacechase0.SpaceCore/ScheduleAnimationExtensionData",
			"Entries":
			{
				"{{ModID}}_TheFishmonger_fish": { 
					"SourceRectSize": "16, 64",
					"DrawOffset": "0, 96",
					"AppearanceOverride": null,
					"OnStart": { "Emote": null, "PlaySound": "slosh" },
					"OnEnd": { "Emote": null, "PlaySound": null },
				}
			}
		},	
		
		//==============================================================================================
		//==== SPACECORE WARP TOTEM ====================================================================
		//==============================================================================================
		{
			"Action": "EditData",
			"Target": "spacechase0.SpaceCore/ObjectExtensionData",
			"Entries": {
				"{{ModId}}_LostIslandTotem": { // The object ID
					"TotemWarp": {
						"Location": "{{ModId}}_LostIsland",
						"Position": "30, 16",
						//"Color": { "R": 0, "G": 0, "B": 255, "A": 255 }
					}
				}
			},
			"When": {
				"HasMod": "spacechase0.SpaceCore",
			}
		},
